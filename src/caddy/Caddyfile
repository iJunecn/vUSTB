# vUSTB / 像素北科 统一网关
# 域名最终为 mc.ustb.edu.cn，开发使用 localhost。
{
    auto_https off
    admin off
}

:80 {
    encode zstd gzip

    # Yggdrasil 对外规范前缀：/skinapi/* → 后端 /api/yggdrasil/*
    # 启动器可填 https://<域名>/skinapi/ 作为 ALI，与后端内部路径解耦
    redir /skinapi /skinapi/ 308
    handle_path /skinapi/* {
        rewrite * /api/yggdrasil{uri}
        reverse_proxy backend:8000
    }

    # 后端 API（Web 业务 + Yggdrasil 协议 /api/yggdrasil/* 内部规范路径）
    handle /api/* {
        reverse_proxy backend:8000
    }

    handle /oauth/* {
        reverse_proxy backend:8000
    }

    handle /.well-known/* {
        reverse_proxy backend:8000
    }

    # 材质静态文件由后端提供 FileResponse
    handle /static/* {
        reverse_proxy backend:8000
    }

    # CustomSkinAPI（CustomSkinLoader Mod 用）
    # 根地址示例: https://mc.ustb.edu.cn/csl/
    handle /csl/* {
        rewrite * /api/csl{uri}
        reverse_proxy backend:8000
    }

    # 其余全部交给 Next.js 前端
    handle {
        reverse_proxy frontend:3000
    }
}
