# === vUSTB 部署环境变量样板 ===
# 复制为 .env 并按需修改

# 站点
SITE_URL=http://localhost
API_URL=http://localhost/skinapi
ENVIRONMENT=production
HOST_HTTP_PORT=80

# 数据库
POSTGRES_USER=vustb
POSTGRES_PASSWORD=please-change-this-password
POSTGRES_DB=vustb

# JWT 密钥（生产环境必须修改为强随机字符串）
JWT_SECRET=please-change-this-to-a-long-random-secret

# CORS（同源部署可保持默认；若前端域名与 API 分离则需添加）
CORS_ALLOW_ORIGINS=["http://localhost","http://localhost:3000"]

# 邮件 SMTP（可选，用于注册验证码、密码重置）
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# OAuth 客户端登录（可选）
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=
